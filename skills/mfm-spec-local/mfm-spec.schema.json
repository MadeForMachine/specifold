{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://madeformachine.com/mfm-spec/0.4/mfm-spec.schema.json",
  "title": "MFM Spec node frontmatter (v0.4)",
  "description": "The YAML frontmatter of a single MFM Spec node file. A node is a component (architecture layer), feature (behavior layer), or evaluation (documented feedback/judgment). Shape only: cross-spec integrity is enforced by the named lint rules, not by this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "kind"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "kind": { "enum": ["component", "feature", "evaluation"] },
    "parent": { "type": ["string", "null"], "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "tier": { "enum": ["core", "experimental"] },
    "status": { "enum": ["draft", "open", "decided", "superseded"] },
    "superseded_by": {
      "description": "Successor node ids for a superseded node — one for a rename or merge, several for a split, none for an outright retire. Same kind as this node; only meaningful with status: superseded.",
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" }
    },
    "open_questions": { "type": "array", "items": { "type": "string" } },
    "responsibility": { "type": "string", "minLength": 1 },
    "depends_on": { "type": "array", "items": { "$ref": "#/$defs/edge" } },
    "intent": { "type": "string", "minLength": 1 },
    "touches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component", "needs"],
        "properties": {
          "component": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
          "needs": { "type": "string", "minLength": 1 }
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "component": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
        "feature": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
        "rev": { "type": "string", "minLength": 1 },
        "variant": { "type": "string", "minLength": 1 },
        "artifact": { "type": "string", "minLength": 1 }
      }
    },
    "verdict": { "enum": ["accepted", "rejected", "mixed", "observed"] },
    "summary": { "type": "string", "minLength": 1 },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "promotes_to_spec": { "type": "array", "items": { "type": "string" } },
    "rejects": { "type": "array", "items": { "type": "string" } }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "component" } }, "required": ["kind"] },
      "then": {
        "required": ["parent", "responsibility"],
        "properties": { "intent": false, "touches": false, "subject": false, "verdict": false, "summary": false, "evidence": false, "promotes_to_spec": false, "rejects": false }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "feature" } }, "required": ["kind"] },
      "then": {
        "required": ["parent", "intent", "touches"],
        "properties": { "responsibility": false, "depends_on": false, "subject": false, "verdict": false, "summary": false, "evidence": false, "promotes_to_spec": false, "rejects": false }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "evaluation" } }, "required": ["kind"] },
      "then": {
        "required": ["subject", "verdict", "summary"],
        "properties": { "parent": false, "responsibility": false, "depends_on": false, "intent": false, "touches": false, "open_questions": false, "status": false, "superseded_by": false }
      }
    }
  ],
  "$defs": {
    "edge": {
      "description": "A dependency edge. Either a bare component id (v0.1 form) or a typed edge.",
      "oneOf": [
        { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["to"],
          "properties": {
            "to": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
            "kind": { "enum": ["consumes", "emits", "uses", "configured-by"] },
            "what": { "type": "string" }
          }
        }
      ]
    }
  }
}
